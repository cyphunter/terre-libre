# ─── Identifiant projet ────────────────────────────────────────────────
SITE_ID=terre-libre

# ─── Variables publiques (accessibles côté client) ─────────────────────
NEXT_PUBLIC_SITE_URL=https://terre-libre.com
NEXT_PUBLIC_MEDIA_BASE=
NEXT_PUBLIC_ENV=development

# ─── Secrets locaux (dev seulement — utiliser `wrangler secret put` en prod) ───
RESEND_API_KEY=re_dev_xxxxxxxxxxxx

# ─── Destinataire des messages du formulaire de contact ────────────────
# En prod, configurer via : wrangler secret put CONTACT_RECIPIENT_EMAIL
CONTACT_RECIPIENT_EMAIL=contact@terre-libre.com
